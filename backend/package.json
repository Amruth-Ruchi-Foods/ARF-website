{
  "name": "arf-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && mkdir -p dist/db && cp src/db/*.sql dist/db/",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "razorpay": "^2.9.6",
    "typescript": "^5.3.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0"
  },
  "overrides": {
    "tar": "^7.5.11",
    "esbuild": "^0.28.1"
  }
}
